# Supabase (client-side, safe to expose)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server-side only, used by edge functions - never ship to the client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI - used by the grade-week edge function
# Leave unset locally and grade-week falls back to a canned mock response
# so the weekly grading loop is testable without spending API credits.
OPENAI_API_KEY=

# Push notifications (Expo). Leave unset and sendPush becomes a console-log no-op.
EXPO_ACCESS_TOKEN=
